{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "apps/*/src",
    "apps/*/tests",
    "packages/*/src",
    "packages/*/tests",
    "*.config.ts",
    "*.config.js"
  ],
  "exclude": ["**/node_modules", "**/dist", "**/build", "**/.turbo"]
}
