# Optional CORS proxy prefix for browser-only mode (Discogs API doesn't send CORS
# headers, so direct fetch() is blocked in pure-web. In Tauri this is not needed —
# requests go through Rust `net_fetch` which ignores CORS.)
# Example: VITE_DISCOGS_PROXY_URL=https://cors.example.com/
#
# In Vite dev mode, the proxy is auto-configured to /discogs-api/ when not in Tauri.
# Set this explicitly only if you use a different CORS proxy.
VITE_DISCOGS_PROXY_URL=
